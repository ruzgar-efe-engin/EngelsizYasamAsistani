{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event Schema",
  "description": "Event sözleşmesi - Cihazdan telefona gönderilen event formatı",
  "type": "object",
  "properties": {
    "type": {
      "type": "integer",
      "enum": [0, 1, 2, 3, 4, 5, 6],
      "description": "Event tipi: 0=THEME_ROTATE, 1=MAIN_ROTATE, 2=SUB_ROTATE, 3=CONFIRM, 4=CANCEL, 5=AI_PRESS, 6=AI_RELEASE"
    },
    "themeIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Tema pozisyon index'i"
    },
    "mainIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Ana menü pozisyon index'i (opsiyonel)"
    },
    "subIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Alt menü pozisyon index'i (opsiyonel)"
    },
    "ts": {
      "type": "integer",
      "minimum": 0,
      "description": "Timestamp (millis()) - debug, debounce, log korelasyonu için"
    }
  },
  "required": ["type", "themeIndex", "ts"]
}

