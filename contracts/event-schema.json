{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event Schema",
  "description": "Event sözleşmesi - Cihazdan telefona gönderilen event formatı",
  "type": "object",
  "properties": {
    "type": {
      "type": "integer",
      "enum": [0, 1, 2, 3, 4, 5],
      "description": "Event tipi: 0=MAIN_ROTATE, 1=SUB_ROTATE, 2=CONFIRM, 3=CANCEL, 4=AI_PRESS, 5=AI_RELEASE"
    },
    "mainIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Ana menü pozisyon index'i (opsiyonel)"
    },
    "subIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Alt menü pozisyon index'i (opsiyonel)"
    },
    "ts": {
      "type": "integer",
      "minimum": 0,
      "description": "Timestamp (millis()) - debug, debounce, log korelasyonu için"
    }
  },
  "required": ["type", "ts"]
}

